# --- Providers ---
OLLAMA_BASE_URL=http://localhost:11434
ACTIVE_BACKEND=openai

# --- Models (Ollama) ---
PRIMARY_MODEL=qwen2.5:7b
FAST_MODEL=qwen2.5:3b

# --- Models (Groq, when ACTIVE_BACKEND=groq) ---
GROQ_API_KEY=
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# --- Models (OpenAI, when ACTIVE_BACKEND=openai) ---
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini

# --- Search ---
TAVILY_API_KEY=

# --- Run Parameters ---
TIME_BUDGET_MINUTES=480
MAX_ITERATIONS=10
MIN_SCORE_IMPROVEMENT=0.02
TARGET_SCORE=0.92
MAX_PARALLEL_AGENTS=1

# --- Tree Execution (v2) ---
MAX_TASK_DEPTH=5
MIN_DECOMPOSE_DEPTH=0

# --- Redis State Store ---
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=slowly
